{
  "name": "modex",
  "version": "0.1.87",
  "description": "Autonomous agentic web interface for AI-assisted development.",
  "type": "module",
  "license": "MIT",
  "author": "Pavel Voronin, Igor Levochkin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pasha01118/Modex-Sandbox-.git"
  },
  "homepage": "https://github.com/pasha01118/Modex-Sandbox-#readme",
  "bugs": {
    "url": "https://github.com/pasha01118/Modex-Sandbox-/issues"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@firebase/util", "node-pty", "protobufjs"]
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "modex",
    "ai",
    "autonomous",
    "web-ui",
    "agent"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "modex": "dist-cli/index.js"
  },
  "files": [
    "dist/",
    "dist-cli/",
    "scripts/dev.cjs",
    "scripts/dev-random-home.cjs",
    "scripts/fix-pty-native-build.cjs"
  ],
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "dev2": "node scripts/dev-random-home.cjs",
    "dev:open": "pnpm run build:cli && sh -c 'pnpm run dev & VPID=$!; node dist-cli/index.js --open-project \"${1:-.}\"; wait $VPID' --",
    "build:frontend": "vue-tsc --noEmit && vite build",
    "build:cli": "tsup",
    "build": "pnpm run build:frontend && pnpm run build:cli",
    "postinstall": "node scripts/fix-pty-native-build.cjs",
    "test:unit": "vitest run",
    "preview": "vite preview",
    "prepublishOnly": "pnpm run build",
    "profile:browser": "node scripts/profile-browser-runtime.cjs",
    "profile:thread": "PROFILE_ROUTE='#/thread/019da7c0-4e12-7a91-837c-f7c11cc8ab6c' node scripts/profile-browser-runtime.cjs"
  },
  "dependencies": {
    "@composio/client": "0.1.0-alpha.66",
    "@socketsecurity/sdk": "^4.0.1",
    "@supabase/supabase-js": "^2.108.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "firebase": "^12.2.1",
    "highlight.js": "^11.11.1",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.3"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.2",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^4.1.5",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.2.0"
  }
}
